# Database - REQUIRED
# Format: postgresql://username:password@host:port/database
# Example: postgresql://myuser:mypass@localhost:5432/monk
# Note: If using PostgreSQL peer authentication, password can be omitted
DATABASE_URL=postgresql://username@localhost:5432/monk

# Server - REQUIRED
PORT=9001

# Environment - REQUIRED
NODE_ENV=development

# JWT Secret - REQUIRED
# SECURITY: Use a strong random value in production
JWT_SECRET=example

# Auth0 broker configuration - REQUIRED for production password auth
# Monk receives tenant + username + password, verifies them through Auth0,
# and then mints a Monk bearer token. Clients do not use Auth0 bearer tokens directly.
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-auth0-app-client-id
# AUTH0_CLIENT_SECRET=your-auth0-app-client-secret
# AUTH0_CONNECTION=Username-Password-Authentication
# AUTH0_AUDIENCE=https://your-monk-api-audience
# Optional separate management credentials if user creation and password verification
# should use different Auth0 applications:
# AUTH0_MANAGEMENT_CLIENT_ID=your-auth0-management-client-id
# AUTH0_MANAGEMENT_CLIENT_SECRET=your-auth0-management-client-secret

# Tenant Naming Mode - OPTIONAL
# Controls how tenant database names are generated during registration
# Options:
#   enterprise - Uses SHA256 hash (tenant_<16-char-hex>) - Default
#   personal   - Allows custom database names (for personal PaaS deployments)
# Default: enterprise
# TENANT_NAMING_MODE=enterprise
