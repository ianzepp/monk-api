{
    "name": "monk-api",
    "version": "6.2.0",
    "description": "Lightweight PaaS backend API built with Hono",
    "agents": "IMPORTANT: Before starting ANY task, READ ./AGENTS.md for project-specific instructions and patterns",
    "main": "dist/index.js",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "start": "bun dist/index.js",
        "start:bg": "nohup bun dist/index.js > /tmp/monk-api.log 2>&1 & echo $!",
        "start:dev": "bun --watch src/index.ts",
        "stop": "pkill -9 -f 'bun.*dist/index' || true",
        "build": "bun run build:packages && scripts/build.sh",
        "build:packages": "bun run --filter '@monk/common' build && bun run --filter '*' build",
        "build:todo": "scripts/build-todos.sh",
        "build:deprecated": "scripts/build-deprecated.sh",
        "build:spec": "scripts/build-spec.sh",
        "test": "bun test --concurrency 1 --timeout 30000 ./spec/**/*.test.ts",
        "test:ts": "bun test --concurrency 1 --timeout 30000 ./spec/**/*.test.ts",
        "test:sh": "scripts/test-sh.sh",
        "test:unit": "bun test --timeout 5000 ./spec/**/*.unit.ts",
        "test:cleanup": "scripts/test-cleanup.sh",
        "fixtures:build": "scripts/fixtures-build.sh",
        "db:local:up": "docker compose -f compose.local.yml up -d",
        "db:local:down": "docker compose -f compose.local.yml down",
        "db:local:reset": "docker compose -f compose.local.yml down -v && docker compose -f compose.local.yml up -d",
        "build:standalone": "scripts/build-standalone.sh"
    },
    "keywords": [
        "hono",
        "api",
        "paas",
        "typescript",
        "postgresql"
    ],
    "author": "Ian Zepp",
    "license": "MIT",
    "dependencies": {
        "hono": "^4.12.10",
        "js-yaml": "^4.1.1",
        "pg": "^8.20.0"
    },
    "optionalDependencies": {
        "@monk/formatter-csv": "workspace:*",
        "@monk/formatter-grid-compact": "workspace:*",
        "@monk/formatter-markdown": "workspace:*",
        "@monk/formatter-msgpack": "workspace:*",
        "@monk/formatter-toon": "workspace:*",
        "@monk/bindings": "workspace:*",
        "@monk-app/grids": "workspace:*",
        "@monk-app/openapi": "workspace:*",
        "@monk-app/todos": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.15.21",
        "@types/pg": "^8.20.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3"
    },
    "engines": {
        "bun": ">=1.0.0"
    }
}
