# Test Environment Configuration
# Uses port 9001 (single port for all environments)

# Database - REQUIRED
# Test uses the dedicated local Docker PostgreSQL instance.
DATABASE_URL=postgresql://monk:monk@127.0.0.1:55432/monk

# Server
PORT=9001
NODE_ENV=test

# Test configuration
TEST_API_URL=http://localhost:9001
TEST_PORT=9001

# JWT Secret
JWT_SECRET=test

# Tenant Naming - Database names are always generated using SHA256 hashing
# This ensures environment isolation and prevents naming conflicts
